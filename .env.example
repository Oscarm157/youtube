# Copia a .env.local y rellena. NUNCA comitees .env.local.
# Postgres (Neon u otro). Driver: @neondatabase/serverless.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Secreto para firmar sesiones. Mínimo 16 chars. Genera uno:
#   openssl rand -base64 32
AUTH_SECRET=

# Opcionales segun lo que uses:
BLOB_READ_WRITE_TOKEN=
RESEND_API_KEY=
EMAIL_FROM=

# CRM (opcionales):
# Destinatario del aviso de lead nuevo (si vacío, usa EMAIL_FROM).
LEAD_RECIPIENT=
# Webhook saliente para cada lead (Zapier/Make/n8n). Vacío = sin webhook.
LEAD_WEBHOOK_URL=
# IA opcional: draft de blog y resumen de leads de bot. Sin key, ambos se omiten.
ANTHROPIC_API_KEY=

# Seed del admin inicial (npm run db:seed). Si vacíos, usa admin@example.com + password random.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Sentry (errores en prod). Sin DSN, Sentry queda inerte (no rompe nada).
NEXT_PUBLIC_SENTRY_DSN=
